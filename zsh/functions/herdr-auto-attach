# herdr auto-attach function
# ログインシェルで herdr の default session に自動アタッチする
# (tmux-auto-attach の herdr 版。PTY はサーバ常駐なので named session 分岐は不要)
# Excludes: VSCode, JetBrains IDEs

herdr-auto-attach() {
  local is_wsl=false
  if [[ -n "${WSL_DISTRO_NAME:-}" || -n "${WSL_INTEROP:-}" ]]; then
    is_wsl=true
  elif [[ -r /proc/sys/kernel/osrelease ]] && grep -qiE 'microsoft|wsl' /proc/sys/kernel/osrelease; then
    is_wsl=true
  fi

  # WSL は Windows 側ターミナルから起動されるため、multiplexer の自動 exec はデフォルトで避ける。
  # 必要な場合は ~/.zsh/.zshrc_local で AUTO_HERDR=true を明示する。
  if [[ -z "${AUTO_HERDR+x}" && "$is_wsl" == "true" ]]; then
    return 0
  fi

  # 設定: herdr自動起動を有効にするか（~/.zshrc_localで上書き可能）
  local AUTO_HERDR="${AUTO_HERDR:-true}"

  # 無効化されている場合はスキップ
  if [[ "$AUTO_HERDR" != "true" ]]; then
    return 0
  fi

  # 既にherdr内にいる場合はスキップ
  if [[ -n "$HERDR_ENV" ]]; then
    return 0
  fi

  # tmux内にいる場合はスキップ（移行完了までの併存。ネスト起動を防ぐ）
  if [[ -n "$TMUX" ]]; then
    return 0
  fi

  # ログインシェルでない場合はスキップ
  if [[ ! "$-" == *l* ]]; then
    return 0
  fi

  # herdrがインストールされていない場合はスキップ
  if ! command -v herdr &> /dev/null; then
    return 0
  fi

  # IDEターミナルの検出と除外
  # VSCode / Cursor
  if [[ -n "$VSCODE_INJECTION" ]] || [[ "$TERM_PROGRAM" == "vscode" ]] || [[ -n "$VSCODE_RESOLVING_ENVIRONMENT" ]] || [[ "$TERM_PROGRAM" == "cursor" ]]; then
    return 0
  fi

  # JetBrains IDEs (IntelliJ, PyCharm, etc.)
  if [[ -n "$TERMINAL_EMULATOR" ]] && [[ "$TERMINAL_EMULATOR" =~ "JetBrains" ]]; then
    return 0
  fi

  # default session に attach（サーバ未起動なら自動起動される）
  exec herdr
}

# 関数を実行
herdr-auto-attach
