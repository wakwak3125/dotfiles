# git worktree ヘルパーコマンド（tmux 統合付き）
# 使い方:
#   wt [-s] add <branch>            - 既存ブランチの worktree を作成（tmux window 自動作成）
#   wt [-s] add -b <branch> [base]  - 新しいブランチを作成して worktree を追加（tmux window 自動作成）
#   wt [-s] rm <branch>             - worktree を削除（tmux window 自動削除）
#   wt [-s] rm .                    - 現在の worktree を削除（tmux window 自動削除）
#   wt [-s] rm -b <branch>          - worktree とブランチを削除（tmux window 自動削除）
#   wt [-s] rm -b .                 - 現在の worktree とブランチを削除（tmux window 自動削除）
#   wt list                         - worktree 一覧を表示
#   wt prune                        - リモート同期 + worktree の整理
#   wt clean                        - リモート同期 + マージ済みブランチ削除 + worktree の整理
#
# オプション:
#   -s, --silent  tmux のウィンドウ作成・切り替え・削除をスキップする

# グローバルオプション解析
local silent=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--silent)
      silent=true
      shift
      ;;
    *)
      break
      ;;
  esac
done

local cmd=$1
shift

# git リポジトリ内でなければ終了
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "エラー: git リポジトリではありません" >&2
  return 1
fi

local repo_root=$(git worktree list | head -1 | awk '{print $1}')
local repo_parent=$(dirname "$repo_root")
local repo_name=$(basename "$repo_root")
local worktree_dir="$repo_parent/worktree/$repo_name"

# tmux 統合用の共通変数
local tmux_session=$(echo "$repo_name" | tr '.' '_')
local in_tmux=false
[[ -n "$TMUX" ]] && in_tmux=true

case "$cmd" in
  add)
    local create_branch=false
    local branch_name=""
    local base_branch=""

    # オプション解析
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -b|--branch)
          create_branch=true
          shift
          ;;
        *)
          if [[ -z "$branch_name" ]]; then
            branch_name=$1
          else
            base_branch=$1
          fi
          shift
          ;;
      esac
    done

    if [[ -z "$branch_name" ]]; then
      echo "使い方: wt add [-b] <branch> [base]" >&2
      echo "  -b, --branch  新しいブランチを作成" >&2
      echo "  base          ベースブランチ（省略時は現在の HEAD）" >&2
      return 1
    fi

    # ディレクトリ名はブランチ名の最後の部分だけを使う (feature/login -> login)
    local dir_name="${branch_name##*/}"

    # worktrees ディレクトリがなければ作成
    mkdir -p "$worktree_dir"

    if [[ "$create_branch" == true ]]; then
      # 新しいブランチを作成して worktree を追加
      if [[ -n "$base_branch" ]]; then
        git worktree add -b "$branch_name" "$worktree_dir/$dir_name" "$base_branch"
      else
        git worktree add -b "$branch_name" "$worktree_dir/$dir_name"
      fi
    else
      # 既存のブランチで worktree を追加
      git worktree add "$worktree_dir/$dir_name" "$branch_name"
    fi

    # tmux 内なら window を自動作成（silent モードではスキップ）
    if [[ "$silent" != true ]] && [[ "$in_tmux" == true ]] && [[ -d "$worktree_dir/$dir_name" ]]; then
      if ! tmux has-session -t "$tmux_session" 2>/dev/null; then
        tmux new-session -d -s "$tmux_session" -c "$worktree_dir/$dir_name" -n "$dir_name"
        tmux switch-client -t "$tmux_session:$dir_name"
      else
        tmux new-window -t "$tmux_session" -n "$dir_name" -c "$worktree_dir/$dir_name"
        local current_session=$(tmux display-message -p '#S')
        if [[ "$current_session" != "$tmux_session" ]]; then
          tmux switch-client -t "$tmux_session:$dir_name"
        else
          tmux select-window -t "$tmux_session:$dir_name"
        fi
      fi
    fi
    ;;

  rm|remove)
    local delete_branch=false
    local branch_name=""

    # オプション解析
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -b|--branch)
          delete_branch=true
          shift
          ;;
        *)
          branch_name=$1
          shift
          ;;
      esac
    done

    if [[ -z "$branch_name" ]]; then
      echo "使い方: wt rm [-b] <branch|.>" >&2
      echo "  -b, --branch  ブランチも削除" >&2
      echo "  .             現在の worktree を対象にする" >&2
      return 1
    fi

    # "." が指定された場合は現在の worktree/ブランチを解決
    if [[ "$branch_name" == "." ]]; then
      local current_wt=$(git rev-parse --show-toplevel 2>/dev/null)
      if [[ "$current_wt" == "$repo_root" ]]; then
        echo "エラー: メインの worktree では実行できません" >&2
        return 1
      fi
      branch_name=$(git symbolic-ref --short HEAD 2>/dev/null)
      if [[ -z "$branch_name" ]]; then
        echo "エラー: 現在のブランチを取得できません" >&2
        return 1
      fi
    fi

    # ディレクトリ名はブランチ名の最後の部分だけを使う (feature/login -> login)
    local dir_name="${branch_name##*/}"
    local worktree_path="$worktree_dir/$dir_name"

    # worktree が存在するか確認
    if [[ ! -d "$worktree_path" ]]; then
      echo "エラー: worktree '$worktree_path' が見つかりません" >&2
      return 1
    fi

    # tmux window の削除判定（silent モードではスキップ）
    local kill_window_after=false
    if [[ "$silent" != true ]] && [[ "$in_tmux" == true ]] && tmux has-session -t "$tmux_session" 2>/dev/null; then
      local current_window=$(tmux display-message -p '#W')
      if [[ "$current_window" == "$dir_name" ]]; then
        # 現在のウィンドウなので worktree 削除後に kill
        kill_window_after=true
      else
        # 別のウィンドウなので先に kill
        tmux kill-window -t "$tmux_session:$dir_name" 2>/dev/null
      fi
    fi

    # worktree を削除
    git worktree remove "$worktree_path"

    # -b オプションが指定された場合はブランチも削除
    if [[ "$delete_branch" == true ]]; then
      git branch -d "$branch_name" 2>/dev/null || git branch -D "$branch_name"
      echo "ブランチ '$branch_name' を削除しました"
    fi

    # 遅延 window 削除
    if [[ "$kill_window_after" == true ]]; then
      tmux kill-window -t "$tmux_session:$dir_name" 2>/dev/null
    fi
    ;;

  list|ls)
    git worktree list
    ;;

  prune)
    # リモートと同期
    echo "リモートを同期中..."
    git fetch --prune

    # worktree の整理
    echo "worktree を整理中..."
    git worktree prune
    echo "完了"
    ;;

  clean)
    # リモートと同期
    echo "リモートを同期中..."
    git fetch --prune

    # ブランチ→worktree パスのマップを構築
    local -A branch_wt_map
    local _wt_path="" _wt_branch=""
    while IFS= read -r line; do
      if [[ "$line" == "worktree "* ]]; then
        _wt_path="${line#worktree }"
      elif [[ "$line" == "branch "* ]]; then
        _wt_branch="${line#branch refs/heads/}"
      elif [[ -z "$line" ]]; then
        if [[ -n "$_wt_branch" && -n "$_wt_path" ]]; then
          branch_wt_map[$_wt_branch]="$_wt_path"
        fi
        _wt_path=""
        _wt_branch=""
      fi
    done < <(git worktree list --porcelain; echo "")

    # 削除対象のブランチを収集（重複排除）
    local -aU delete_targets

    # 1. main/master/develop のいずれかにマージ済みのブランチ
    for base in main master develop; do
      git show-ref --verify --quiet "refs/heads/$base" 2>/dev/null || continue
      while IFS= read -r b; do
        delete_targets+=("$b")
      done < <(git branch --merged "$base" | grep -v -E "^\*|^\s*(main|master|develop)$" | sed 's/^[+ ]*//')
    done

    # 2. リモートで削除済み（gone）のブランチ
    while IFS= read -r b; do
      delete_targets+=("$b")
    done < <(git branch -vv | grep ': gone]' | sed 's/^[* +]*//' | awk '{print $1}' | grep -v -E "^(main|master|develop)$")

    if (( ${#delete_targets[@]} > 0 )); then
      # 関数スコープで job 通知を抑止（[N] PID / [N] done のログを止める）
      setopt local_options no_monitor no_notify

      local total=${#delete_targets[@]}
      local jobs_max=${WT_CLEAN_JOBS:-4}
      local is_tty=false
      [[ -t 2 ]] && is_tty=true

      # 進捗表示用 FIFO（バックグラウンドジョブからのイベントを集約）
      local progress_fifo=$(mktemp -u)
      mkfifo "$progress_fifo"

      # 進捗表示プロセス（バックグラウンド）
      # プロトコル: "START<TAB>branch" / "END<TAB>OK|SKIP|FAIL<TAB>branch"
      {
        local -A inflight
        local done_count=0
        local -a results
        local CR=$'\r' CLR=$'\033[K'
        if [[ "$is_tty" != true ]]; then
          CR=""
          CLR=""
        fi

        _redraw() {
          if [[ "$is_tty" == true ]]; then
            local list="${(j:, :)${(k)inflight}}"
            [[ -z "$list" ]] && list="(待機中)"
            printf "%s%s  [%d/%d] 処理中: %s" "$CR" "$CLR" "$done_count" "$total" "$list" >&2
          fi
        }

        while IFS=$'\t' read -r kind status branch; do
          case "$kind" in
            START)
              inflight[$status]=1   # status 列が branch 名（START の場合）
              _redraw
              ;;
            END)
              done_count=$((done_count + 1))
              unset "inflight[$branch]"
              case "$status" in
                OK)   results+=("  ✓ $branch") ;;
                SKIP) results+=("  - スキップ（未コミット変更あり）: $branch") ;;
                FAIL) results+=("  ✗ ブランチ削除失敗: $branch") ;;
              esac
              _redraw
              ;;
          esac
        done < "$progress_fifo"

        # 最終行をクリアしてサマリを出力
        if [[ "$is_tty" == true ]]; then
          printf "%s%s" "$CR" "$CLR" >&2
        fi
        printf "%s\n" "${results[@]}" >&2
      } &
      local progress_pid=$!

      # FIFO 書き込み側を親で開いておく（read 側が EOF を取らないように）
      exec 9>"$progress_fifo"

      # クリーンアップ（冪等: 何度呼んでも安全）
      local _wt_clean_done=false
      _wt_clean_cleanup() {
        [[ "$_wt_clean_done" == true ]] && return
        _wt_clean_done=true
        # FIFO の write 側を閉じて進捗 reader に EOF を送る
        exec 9>&- 2>/dev/null
        # 残ってる子ジョブ（worker / progress reader）を終了
        local pid
        for pid in ${(k)jobstates}; do
          kill -TERM "$pid" 2>/dev/null
        done
        wait 2>/dev/null
        rm -f "$progress_fifo"
      }
      # INT/TERM: cleanup + 中断メッセージ + 130 で return
      trap '_wt_clean_cleanup; printf "\n中断しました\n" >&2; return 130' INT TERM
      # EXIT: 関数終了時に必ず cleanup（正常終了でも保険として走る）
      trap '_wt_clean_cleanup' EXIT

      # 並列ジョブ管理
      local running=0
      for branch in "${delete_targets[@]}"; do
        # 並列数の上限に達したら 1 つ終わるのを待つ
        while (( running >= jobs_max )); do
          wait -n 2>/dev/null
          running=$((running - 1))
        done

        local wt_for_branch="${branch_wt_map[$branch]}"
        local wt_dir_name=""
        [[ -n "$wt_for_branch" ]] && wt_dir_name=$(basename "$wt_for_branch")

        # tmux window を閉じる（前段で順次実行: tmux IPC は並列の意味なし）
        if [[ -n "$wt_dir_name" ]] && [[ "$silent" != true ]] && [[ "$in_tmux" == true ]] \
            && tmux has-session -t "$tmux_session" 2>/dev/null; then
          tmux kill-window -t "$tmux_session:$wt_dir_name" 2>/dev/null
        fi

        # 削除処理をバックグラウンドで実行
        {
          print -u 9 -r -- "START	$branch"
          if [[ -n "$wt_for_branch" && -d "$wt_for_branch" ]]; then
            if ! git worktree remove "$wt_for_branch" >/dev/null 2>&1; then
              print -u 9 -r -- "END	SKIP	$branch"
              exit 0
            fi
          fi
          if git branch -d "$branch" >/dev/null 2>&1 || git branch -D "$branch" >/dev/null 2>&1; then
            print -u 9 -r -- "END	OK	$branch"
          else
            print -u 9 -r -- "END	FAIL	$branch"
          fi
        } &
        running=$((running + 1))
      done

      # 残りのワーカーを待機（progress reader は cleanup で終了させる）
      while (( running > 0 )); do
        wait -n 2>/dev/null
        running=$((running - 1))
      done

      # 正常終了パスでも cleanup を走らせる（FIFO 閉じる→reader 終了→FIFO 削除）
      _wt_clean_cleanup
      # trap を解除して関数を破棄
      trap - INT TERM EXIT
      unset -f _wt_clean_cleanup
    else
      echo "削除対象のブランチはありません"
    fi

    # worktree の整理
    echo "worktree を整理中..."
    git worktree prune
    echo "完了"
    ;;

  *)
    echo "使い方: wt [-s] <command> [args]"
    echo ""
    echo "オプション:"
    echo "  -s, --silent            tmux 操作をスキップ（ブランチ・worktree 操作のみ実行）"
    echo ""
    echo "コマンド:"
    echo "  add <branch>            既存ブランチの worktree を作成"
    echo "  add -b <branch> [base]  新しいブランチを作成して worktree を追加（base 省略時は HEAD）"
    echo "  rm <branch|.>           worktree を削除（. で現在の worktree）"
    echo "  rm -b <branch|.>        worktree とブランチを削除（. で現在の worktree）"
    echo "  list                    worktree 一覧を表示"
    echo "  prune                   リモート同期 + worktree の整理"
    echo "  clean                   リモート同期 + マージ済みブランチ削除 + worktree の整理"
    ;;
esac
