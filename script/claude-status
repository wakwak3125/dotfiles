#!/usr/bin/env bash
# claude-status: Claude Code セッションステータスダッシュボード
#
# 使い方:
#   claude-status update      - stdin から JSON を読みステータスを更新（PreToolUse hooks 用）
#   claude-status idle        - ステータスを待機中に設定（Stop hooks 用）
#   claude-status clear       - ステータスを削除
#   claude-status dashboard   - インタラクティブダッシュボードを表示
#   claude-status cleanup     - 古いエントリを削除

STATUS_DIR="/tmp/claude-status"
STALE_THRESHOLD=300  # 5分で stale 扱い

mkdir -p "$STATUS_DIR"

# tmux pane が存在するか確認
is_pane_alive() {
  local pane="$1"
  [[ -z "$pane" ]] && return 1
  tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -qF "$pane"
}

# jq チェック
if ! command -v jq &>/dev/null; then
  echo "エラー: jq が必要です (brew install jq)" >&2
  exit 1
fi

# セッション識別子（tmux pane ID or PID）
get_session_id() {
  if [[ -n "${TMUX_PANE:-}" ]]; then
    echo "${TMUX_PANE//%/}"
  else
    echo "pid_${PPID}"
  fi
}

# ──────────────────────────────────────────────────────
# update: PreToolUse hook から呼ばれる
# stdin に hook JSON が渡される
# ──────────────────────────────────────────────────────
cmd_update() {
  local input
  input=$(cat)

  local session_id
  session_id=$(get_session_id)
  local status_file="$STATUS_DIR/${session_id}.json"

  local tool_name detail

  tool_name=$(echo "$input" | jq -r '.tool_name // empty' 2>/dev/null)

  # Claude Code と同じ形式でツール操作テキストを構築
  case "$tool_name" in
    Bash)
      # description があればそれを使い、なければコマンドを使う
      detail=$(echo "$input" | jq -r '.tool_input.description // empty' 2>/dev/null)
      if [[ -z "$detail" ]]; then
        detail=$(echo "$input" | jq -r '.tool_input.command // empty' 2>/dev/null | head -1 | cut -c1-60)
      fi
      ;;
    Read|Write|Edit)
      local path
      path=$(echo "$input" | jq -r '.tool_input.file_path // empty' 2>/dev/null | sed "s|$HOME|~|")
      detail="${tool_name} ${path}"
      ;;
    Grep)
      local pattern
      pattern=$(echo "$input" | jq -r '.tool_input.pattern // empty' 2>/dev/null | cut -c1-30)
      detail="Grep ${pattern}"
      ;;
    Glob)
      local pattern
      pattern=$(echo "$input" | jq -r '.tool_input.pattern // empty' 2>/dev/null)
      detail="Glob ${pattern}"
      ;;
    Agent)
      detail=$(echo "$input" | jq -r '.tool_input.description // empty' 2>/dev/null | cut -c1-50)
      ;;
    Task)
      detail=$(echo "$input" | jq -r '.tool_input.description // empty' 2>/dev/null | cut -c1-50)
      ;;
    *)
      detail="$tool_name"
      ;;
  esac

  # 改行・余分な空白を除去して1行にし、長すぎる場合は切り詰める
  detail=$(echo "$detail" | tr '\n' ' ' | sed 's/  */ /g; s/^[[:space:]]*//; s/[[:space:]]*$//' | cut -c1-80)

  # tool_count と start_ts をトラッキング
  local tool_count=1
  local now
  now=$(date +%s)
  local start_ts="$now"

  if [[ -f "$status_file" ]]; then
    local prev_tool
    prev_tool=$(jq -r '.tool // "idle"' "$status_file" 2>/dev/null)
    if [[ "$prev_tool" != "idle" ]]; then
      local prev_count prev_start
      prev_count=$(jq -r '.tool_count // 0' "$status_file" 2>/dev/null)
      prev_start=$(jq -r '.start_ts // 0' "$status_file" 2>/dev/null)
      tool_count=$((prev_count + 1))
      [[ "$prev_start" -gt 0 ]] 2>/dev/null && start_ts="$prev_start"
    fi
  fi

  # Git 情報（キャッシュで高速化）
  if [[ -z "${_CS_REPO:-}" ]]; then
    export _CS_REPO=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null || echo "?")
    export _CS_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
  fi
  local repo="${_CS_REPO}"
  local branch="${_CS_BRANCH}"

  # tmux 情報（キャッシュで高速化）
  local tmux_session="" tmux_window=""
  if [[ -n "${TMUX:-}" ]]; then
    if [[ -z "${_CS_TMUX_SESSION:-}" ]]; then
      export _CS_TMUX_SESSION=$(tmux display-message -p '#S' 2>/dev/null || echo "")
      export _CS_TMUX_WINDOW=$(tmux display-message -p '#W' 2>/dev/null || echo "")
    fi
    tmux_session="${_CS_TMUX_SESSION}"
    tmux_window="${_CS_TMUX_WINDOW}"
  fi

  # ステータスファイルに書き込み
  jq -n \
    --arg repo "$repo" \
    --arg branch "$branch" \
    --arg tool "$tool_name" \
    --arg detail "$detail" \
    --argjson tool_count "$tool_count" \
    --argjson start_ts "$start_ts" \
    --arg session "$tmux_session" \
    --arg window "$tmux_window" \
    --arg pane "${TMUX_PANE:-}" \
    --argjson ts "$now" \
    '{repo:$repo, branch:$branch, tool:$tool, detail:$detail, tool_count:$tool_count, start_ts:$start_ts, session:$session, window:$window, pane:$pane, ts:$ts}' \
    > "$STATUS_DIR/${session_id}.json"
}

# ──────────────────────────────────────────────────────
# idle: Stop hook から呼ばれる
# stdin に {"last_assistant_message": "..."} 等が渡される
# ──────────────────────────────────────────────────────
cmd_idle() {
  local input
  input=$(cat)

  local session_id
  session_id=$(get_session_id)
  local status_file="$STATUS_DIR/${session_id}.json"

  # Claude の最終応答テキスト（1行目を detail として表示）
  local detail=""
  detail=$(echo "$input" | jq -r '.last_assistant_message // ""' 2>/dev/null \
    | tr '\n' ' ' | sed 's/  */ /g; s/^[[:space:]]*//' | cut -c1-80)

  if [[ -f "$status_file" ]]; then
    local tmp
    tmp=$(mktemp)
    jq --argjson ts "$(date +%s)" --arg detail "$detail" \
      '.tool = "idle" | .detail = (if $detail != "" then $detail else .detail end) | .tool_count = 0 | .ts = $ts' \
      "$status_file" > "$tmp" && mv "$tmp" "$status_file"
  fi
}

# ──────────────────────────────────────────────────────
# clear: セッション終了時に呼ばれる
# ──────────────────────────────────────────────────────
cmd_clear() {
  cat > /dev/null 2>/dev/null
  local session_id
  session_id=$(get_session_id)
  rm -f "$STATUS_DIR/${session_id}.json"
}

# ──────────────────────────────────────────────────────
# dashboard: インタラクティブダッシュボード
# ──────────────────────────────────────────────────────
cmd_dashboard() {
  local BOLD='\033[1m'
  local DIM='\033[2m'
  local GREEN='\033[32m'
  local BLUE='\033[34m'
  local CYAN='\033[36m'
  local MAGENTA='\033[35m'
  local YELLOW='\033[33m'
  local RESET='\033[0m'

  local spinner_frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')

  tput civis 2>/dev/null
  trap 'tput cnorm 2>/dev/null; tput ed 2>/dev/null; exit 0' EXIT INT TERM
  clear

  while true; do
    tput home

    local cols
    cols=$(stty size </dev/tty 2>/dev/null | awk '{print $2}')
    [[ -z "$cols" || "$cols" -le 0 ]] 2>/dev/null && cols=$(tput cols 2>/dev/null)
    [[ -z "$cols" || "$cols" -le 0 ]] 2>/dev/null && cols=80
    local pad_lr=2
    local pad_str
    pad_str=$(printf '%*s' "$pad_lr" '')
    local inner=$((cols - pad_lr * 2))
    local separator
    separator=$(printf '%*s' "$inner" '' | tr ' ' '─')

    local now
    now=$(date +%s)
    local frame_idx=$((now % 10))
    local spinner="${spinner_frames[$frame_idx]}"
    local buf=""

    buf+=$'\n'
    buf+="${pad_str}${BOLD}${CYAN}Claude Code ダッシュボード${RESET}"
    local pad=$((inner - 26 - 11))
    (( pad < 1 )) && pad=1
    buf+="$(printf '%*s' "$pad" '')${DIM}ESC: 閉じる${RESET}"$'\n'
    buf+="${pad_str}${DIM}${separator}${RESET}"$'\n'

    local has_sessions=false
    local entries=()

    for f in "$STATUS_DIR"/*.json; do
      [[ -f "$f" ]] || continue

      local ts pane_id
      ts=$(jq -r '.ts' "$f" 2>/dev/null)
      [[ -z "$ts" || "$ts" == "null" ]] && { rm -f "$f"; continue; }

      pane_id=$(jq -r '.pane // ""' "$f" 2>/dev/null)
      if [[ -n "$pane_id" ]] && ! is_pane_alive "$pane_id"; then
        rm -f "$f"
        continue
      fi

      local age=$((now - ts))
      (( age > STALE_THRESHOLD )) && continue

      has_sessions=true
      entries+=("$f")
    done

    if [[ "$has_sessions" == true ]]; then
      for f in "${entries[@]}"; do
        local repo branch tool detail tool_count start_ts ts session window
        repo=$(jq -r '.repo' "$f" 2>/dev/null)
        branch=$(jq -r '.branch' "$f" 2>/dev/null)
        tool=$(jq -r '.tool' "$f" 2>/dev/null)
        detail=$(jq -r '.detail // ""' "$f" 2>/dev/null)
        tool_count=$(jq -r '.tool_count // 0' "$f" 2>/dev/null)
        start_ts=$(jq -r '.start_ts // 0' "$f" 2>/dev/null)
        ts=$(jq -r '.ts' "$f" 2>/dev/null)
        session=$(jq -r '.session // ""' "$f" 2>/dev/null)
        window=$(jq -r '.window // ""' "$f" 2>/dev/null)

        # セッションラベル
        local label
        if [[ -n "$session" && -n "$window" ]]; then
          label="${session}/${window}"
        elif [[ -n "$repo" ]]; then
          label="$repo"
        else
          label="?"
        fi

        # ブランチ短縮
        branch="${branch##*/}"

        # ヘッダー行: session (repo:branch)
        buf+="${pad_str}${BOLD}${BLUE}${label}${RESET} ${DIM}(${repo}:${MAGENTA}${branch}${RESET}${DIM})${RESET}"$'\n'

        if [[ "$tool" == "idle" || -z "$tool" ]]; then
          # 待機中: detail を画面幅に収める
          # "  ● 待機 · " = 10文字 + pad_lr*2 + 2(indent)
          local max_detail=$((inner - 12))
          local trunc_detail="$detail"
          [[ ${#trunc_detail} -gt $max_detail ]] && trunc_detail="${trunc_detail:0:$((max_detail - 1))}…"
          local idle_line="  ${DIM}● 待機"
          [[ -n "$trunc_detail" ]] && idle_line+=" · ${trunc_detail}"
          idle_line+="${RESET}"
          buf+="${pad_str}${idle_line}"$'\n'
        else
          # 実行中
          local elapsed=0
          [[ "$start_ts" -gt 0 ]] 2>/dev/null && elapsed=$((now - start_ts))
          local elapsed_str
          if (( elapsed < 60 )); then
            elapsed_str="${elapsed}s"
          else
            elapsed_str="$((elapsed / 60))m$((elapsed % 60))s"
          fi

          # detail を画面幅に収める
          # "  ⠙ " + " (+N)" + " · 99m99s" ≒ 最大20文字のオーバーヘッド + indent 2
          local overhead=6  # "  ⠙ " + trailing space
          [[ "$tool_count" -gt 1 ]] && overhead=$((overhead + 4 + ${#tool_count}))
          overhead=$((overhead + 3 + ${#elapsed_str}))  # " · Ns"
          local max_detail=$((inner - overhead))
          local trunc_detail="$detail"
          [[ ${#trunc_detail} -gt $max_detail ]] && trunc_detail="${trunc_detail:0:$((max_detail - 1))}…"

          local active_line="  ${GREEN}${spinner}${RESET} ${trunc_detail}"
          if [[ "$tool_count" -gt 1 ]]; then
            active_line+=" ${YELLOW}(+$((tool_count - 1)))${RESET}"
          fi
          active_line+=" ${DIM}· ${elapsed_str}${RESET}"
          buf+="${pad_str}${active_line}"$'\n'
        fi

        buf+=$'\n'
      done
    else
      buf+=$'\n'
      buf+="${pad_str}${DIM}アクティブな Claude Code セッションはありません${RESET}"$'\n'
      buf+=$'\n'
    fi

    buf+="${pad_str}${DIM}${separator}${RESET}"$'\n'
    buf+="${pad_str}${DIM}更新間隔: 1s | セッション数: ${#entries[@]}${RESET}"$'\n'

    echo -ne "$buf"
    tput ed

    read -t 1 -n 1 -s key 2>/dev/null && [[ "$key" == $'\e' ]] && break
  done
}

# ──────────────────────────────────────────────────────
# cleanup: 古いエントリを削除
# ──────────────────────────────────────────────────────
cmd_cleanup() {
  local now
  now=$(date +%s)
  local count=0

  for f in "$STATUS_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    local ts pane_id
    ts=$(jq -r '.ts' "$f" 2>/dev/null)
    [[ -z "$ts" || "$ts" == "null" ]] && { rm -f "$f"; ((count++)); continue; }

    pane_id=$(jq -r '.pane // ""' "$f" 2>/dev/null)
    if [[ -n "$pane_id" ]] && ! is_pane_alive "$pane_id"; then
      rm -f "$f"
      ((count++))
      continue
    fi

    local age=$((now - ts))
    if (( age > STALE_THRESHOLD )); then
      rm -f "$f"
      ((count++))
    fi
  done

  echo "${count} 件のエントリを削除しました"
}

# ──────────────────────────────────────────────────────
# メインディスパッチ
# ──────────────────────────────────────────────────────
case "${1:-}" in
  update)    cmd_update ;;
  idle)      cmd_idle ;;
  clear)     cmd_clear ;;
  dashboard) cmd_dashboard ;;
  cleanup)   cmd_cleanup ;;
  *)
    echo "使い方: claude-status <command>"
    echo ""
    echo "コマンド:"
    echo "  update      ステータスを更新（PreToolUse hook 用）"
    echo "  idle        ステータスを待機中に（Stop hook 用）"
    echo "  clear       ステータスを削除"
    echo "  dashboard   インタラクティブダッシュボード"
    echo "  cleanup     古いエントリを削除"
    ;;
esac
