{
  "meta": {
    "name": "yolo",
    "version": "1.0.0",
    "description": "claude-code profile with SSH and dev tool access for yolo sessions"
  },
  "extends": "claude-code",
  "filesystem": {
    "read": [
      "$HOME/.local/share/mise",
      "$HOME/.local/bin",
      "$HOME/delta",
      "$HOME/.ssh/config"
    ],
    "allow_file": [
      "$HOME/.ssh/known_hosts"
    ]
  }
}
