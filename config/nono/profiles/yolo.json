{
  "meta": {
    "name": "yolo",
    "version": "1.0.0",
    "description": "claude-code profile with SSH and dev tool access for yolo sessions"
  },
  "extends": "claude-code",
  "policy": {
    "add_allow_read": [
      "$HOME/.local/share/mise",
      "$HOME/.local/bin",
      "$HOME/delta"
    ],
    "add_allow_readwrite": [
      "$HOME/.ssh"
    ]
  }
}
